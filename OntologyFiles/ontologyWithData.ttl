          :nameOfSupervisor "Andreas Andrikopoulos" ;
          :numberOfPages "81" ;
          :program "MBA Χίος" ;
          :title "Δυναμικές συσχετίσεις μεταξύ των ναυλαγορών και της αγοράς των εμπορευμάτων" ;
          :typeOfDissertation "MasterThesis" .


