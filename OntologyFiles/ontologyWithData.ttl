###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#fathersName
:fathersName rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Writer ;
             rdfs:range xsd:string ;
             rdfs:label "fathersName"@en ,
                        "Πατρώνυμο"@el .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#firstName
:firstName rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf owl:topDataProperty ;
           rdfs:domain :Writer ;
           rdfs:range xsd:string ;
           rdfs:label "firstName"@en ,
                      "Όνομα"@el ;
           rdfs:seeAlso "https://schema.org/givenName"^^xsd:anyURI .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#gender
:gender rdf:type owl:DatatypeProperty ,
                 owl:FunctionalProperty ;
        rdfs:domain :Writer ;
        rdfs:range [ rdf:type rdfs:Datatype ;
                     owl:oneOf [ rdf:type rdf:List ;
                                 rdf:first "Άνδρας" ;
                                 rdf:rest [ rdf:type rdf:List ;
                                            rdf:first "Γυναίκα" ;
                                            rdf:rest rdf:nil
                                          ]
                               ]
                   ] ;
        rdfs:label "gender"@en ,
                   "Φύλο"@el ;
        rdfs:seeAlso "https://schema.org/gender"^^xsd:anyURI .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#geographicalUnit
:geographicalUnit rdf:type owl:DatatypeProperty ;
