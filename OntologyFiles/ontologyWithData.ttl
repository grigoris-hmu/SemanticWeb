#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#BachelorsThesis
:BachelorsThesis rdf:type owl:Class ;
                 rdfs:subClassOf :Dissertation ;
                 rdfs:label "Bachelors Thesis"@en ,
                            "Πτυχιακή Εργασία"@el .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#Dissertation
:Dissertation rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty :hasWriter ;
                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :Writer
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :abstract ;
                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :title ;
                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :dateOfSupport ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:date
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :institution ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ;
              rdfs:isDefinedBy "https://schema.org/Thesis" ;
              rdfs:label "Dissertation"@en ,
                         "Διατριβή"@el .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#DoctoralDissertation
:DoctoralDissertation rdf:type owl:Class ;
                      rdfs:subClassOf :Dissertation ;
                      rdfs:label "Doctoral Dissertation"@en ,
                                 "Διδακτορική Διατριβή"@el .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#MasterThesis
:MasterThesis rdf:type owl:Class ;
              rdfs:subClassOf :Dissertation ;
              rdfs:label "Master Thesis"@en ,
                         "Μεταπτυχιακή Διπλωματική Εργασία"@el .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#Mixed
:Mixed rdf:type owl:Class ;
       rdfs:subClassOf :Survey .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#Qualitative
:Qualitative rdf:type owl:Class ;
             rdfs:subClassOf :Survey ;
             rdfs:label "Qualitative Survey"@en ,
                        "Ποιοτική Έρευνα"@el .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#Quantitative
:Quantitative rdf:type owl:Class ;
              rdfs:subClassOf :Survey ;
              rdfs:label "Quantitative Survey"@en ,
                         "Ποσοτική Έρευνα"@el .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#Sample
:Sample rdf:type owl:Class ;
        rdfs:label "Sample"@en ,
                   "Δείγμα"@el .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#Spacetime
:Spacetime rdf:type owl:Class ;
           rdfs:label "Spacetime"@en ,
                      "Χωροχρονικό Πλαίσιο"@el .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#Survey
:Survey rdf:type owl:Class ;
        rdfs:label "Survey"@en ,
                   "Έρευνα"@el .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#Writer
:Writer rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :firstName ;
                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :surName ;
                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :fathersName ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :gender ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ;
        rdfs:isDefinedBy "https://schema.org/author"^^xsd:anyURI ;
        rdfs:label "Writer"@en ,
                   "Συγγραφέας"@el ;
        rdfs:seeAlso "http://purl.org/dc/terms/creator"^^xsd:anyURI ,
                     "https://schema.org/Person"^^xsd:anyURI .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/team1/ontologies/semantic-web-project/SampleID_1
:SampleID_1 rdf:type owl:NamedIndividual ,
                   :Sample ;
          :basicUnit "μηνιαίες Εκθέσεις Ελέγχου" ;
          :collectionMethod "Σκόπιμη δειγματοληψία" ;
          :geographicalUnit "Νήσος Λέρος" ;
          :methodOfAnalysis "περιγραφική ανάλυση, επανέλεγχος" ;
          :methodOfRecording "επισκόπηση των μηνιαίων Εκθέσεων Ελέγχου, συνεντεύξεις" ;
          :recordingTools "Εκθέσεις Ελέγχου" ;
          :sampleDescription "Διοίκηση και Εσωτερικοί Ελεγκτές του Γενικού Νοσοκομείου Λέρου" ;
          :sampleSize "18" ;
          :sampleTimeReference "από τον Ιανουάριο του 2013 έως τον Δεκέμβριο του έτους 2018" ;
          :spatialCoverage "Λέρος" ;
          :statesOfReference "Ελλάδα" .
:SurveyID_1 rdf:type owl:NamedIndividual ,
                   :Survey ;
          :hasSample :SampleID_1 ;
