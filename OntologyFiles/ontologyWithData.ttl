          rdfs:range xsd:string ;
          rdfs:label "alternativeHeadline"@en ,
                     "Εναλλακτικός Τίτλος"@el ;
          rdfs:seeAlso "http://purl.org/dc/terms/alternative"^^xsd:anyURI ,
                       "https://schema.org/alternativeHeadline"^^xsd:anyURI .


