:ThesisID_1 rdf:type owl:NamedIndividual ,
                   :MasterThesis ;
          :hasSurvey :SurveyID_1 ;
          :hasWriter :WriterID_1 ;
          :abstract "Η συγκεκριμένη μελέτη περίπτωσης ασχολείται με την καταγραφή των κυριότερων αποτελεσμάτων, που προέκυψαν μέσω της συνεργασίας ανάμεσα στη Διοίκηση του Κρατικού Θεραπευτηρίου- Γενικού Νοσοκομείου- Κ.Υ Λέρου (Κ.Θ-Κ.Υ ΛΕΡΟΥ) και των συνολικά δύο Εσωτερικών Ελεγκτών του Νοσοκομείου, από τον Ιανουάριο του 2013 έως τον Δεκέμβριο του έτους 2018. Σκοπός της εργασίας είναι να διερευνηθεί αν ο Εσωτερικός έλεγχος αποτελεί χρήσιμο εργαλείο στα χέρια της Διοίκησης, προκειμένου η τελευταία να πετύχει τους στόχους της, οικονομικούς και μη. Επίσης διερευνάται κατά πόσο η Διοίκηση μεριμνά ώστε να αξιοποιήσει στο έπακρο τις δυνατότητες που της παρέχει η εν λόγω συνεργασία. Η εστίαση της έρευνάς αφορά τον αντίκτυπο που είχαν οι υπηρεσίες του εσωτερικού ελέγχου και η υλοποίηση των σχετικών εισηγήσεων του από τη Διοίκηση." ;
          :alternativeHeadline "leros_hospital_system_of_internal_controls" ;
          :dateOfSupport "2020-04-01"^^xsd:date ;
          :department "Τμημα Διοίκησης Επιχειρήσεων" ;
          :institution "Πανεπιστήμιο Αιγαίου" ;
          :keyWords "Κρατικό θεραπευτήριο-Γενικό Νοσοκομείο-Κ.Υ. Λέρου, Εσωτερικός Έλεγχος, Εκθέσεις Ελέγχου, Επιτροπή Ελέγχου" ;
          :language "Greek" ;
          :libraryLink "http://hdl.handle.net/11610/22107" ;
          :nameOfSupervisor "ΚΟΥΤΟΥΠΗΣ ΑΝΔΡΕΑΣ" ;
          :numberOfPages "126" ;
          :program "ΜΕΤΑΠΤΥΧΙΑΚΟ ΠΡΟΓΡΑΜΜΑ ΣΠΟΥΔΩΝ ΓΙΑ ΣΤΕΛΕΧΗ Executive MBA" ;
          :title "«ΤΟ ΣΥΣΤΗΜΑ ΕΣΩΤΕΡΙΚΟΥ ΕΛΕΓΧΟΥ ΤΟΥ ΚΡΑΤΙΚΟΥ ΘΕΡΑΠΕΥΤΗΡΙΟΥ -ΓΕΝΙΚΟΥ ΝΟΣΟΚΟΜΕΙΟΥ – ΚΕΝΤΡΟΥ ΥΓΕΙΑΣ ΛΕΡΟΥ, Ο ΡΟΛΟΣ ΤΟΥ ΕΣΩΤΕΡΙΚΟΥ ΕΛΕΓΧΟΥ ΣΤΗΝ ΕΝΔΥΝΑΜΩΣΗ ΤΗΣ ΔΙΑΧΕΙΡΙΣΗΣ ΚΙΝΔΥΝΟΥ»" ;
          :typeOfDissertation "MasterThesis" .


