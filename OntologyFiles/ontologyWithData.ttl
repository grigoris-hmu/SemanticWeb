                  rdfs:label "collectionMethod"@en ,
                             "Μέθοδος Συλλογής"@el ;
                  rdfs:seeAlso "https://schema.org/measurementTechnique"^^xsd:anyURI .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#dateOfSupport
:dateOfSupport rdf:type owl:DatatypeProperty ;
               rdfs:domain :Dissertation ;
               rdfs:range xsd:date ;
               rdfs:label "dateOfSupport"@en ,
