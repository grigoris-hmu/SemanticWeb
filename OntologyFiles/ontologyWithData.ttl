:ThesisID_2 rdf:type owl:NamedIndividual ,
                   :MasterThesis ;
          :hasSurvey :SurveyID_2 ;
          :hasWriter :WriterID_2 ;
          :abstract "Έχουν περάσει πάνω από 30 χρόνια από τότε που πρωτοεμφανίσθηκε η έννοια του Εσωτερικού Μάρκετινγκ (ΕΜ). Μαζί με την πολυδιάστατη αυτή έννοια, αναλύονται επιπλέον, τέσσερις στενά συνδεδεμένες έννοιες, αυτή της Ποιότητας Εργασιακής Ζωής (ΠΕΖ), της Εργασιακής Ικανοποίησης, της Οργανωσιακής Δέσμευσης και της Πρόθεσης Παραμονής στην Επιχείρηση. Συγκεκριμένα, στόχος της παρούσας εργασίας είναι να διερευνηθεί ο βαθμός στον οποίο οι επιχειρήσεις στον κλάδο της καφεστίασης εφαρμόζουν πρακτικές ΕΜ, δηλαδή το αν υιοθετούν τη φιλοσοφία του εσωτερικού πελάτη, και κατά πόσο η εφαρμογή τους επηρεάζει σημαντικές μεταβλητές της εργασιακής ζωής." ;
          :alternativeHeadline "Internal Marketing" ;
          :dateOfSupport "2020-10-01"^^xsd:date ;
          :department "Τμήμα Διοίκησης Επιχειρήσεων" ;
          :institution "Πανεπιστήμιο Αιγαίου" ;
          :keyWords "εσωτερικό μάρκετινγκ, ποιότητα εργασιακής ζωής, εργασιακή ικανοποίηση, οργανωσιακή δέσμευση, πρόθεση παραμονής, εργασιακές στάσεις" ;
          :language "Ελληνικά" ;
          :libraryLink "http://hdl.handle.net/11610/22103" ;
          :nameOfSupervisor "Νίκη Γλαβέλη" ;
          :numberOfPages "141" ;
          :program "Πρόγραμμα Μεταπτυχιακών Σπουδών στη Διοίκηση Επιχειρήσεων για Στελέχη - Executive ΜΒΑ" ;
          :title "Eσωτερικό Μάρκετινγκ (Internal Μarketing), ποιότητα εργασιακής ζωής και στάσεις των εργαζομένων: Μία διερευνητική μελέτη στον κλάδο της καφεστίασης." ;
          :typeOfDissertation "MasterThesis" .


