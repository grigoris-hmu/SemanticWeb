@prefix : <http://www.semanticweb.org/team1/ontologies/semantic-web-project/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@base <http://www.semanticweb.org/team1/ontologies/semantic-web-project/> .

<http://www.semanticweb.org/team1/ontologies/semantic-web-project> rdf:type owl:Ontology .

#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#hasSample
:hasSample rdf:type owl:ObjectProperty ;
           rdfs:domain :Survey ;
           rdfs:range :Sample ;
           rdfs:label "hasSample"@en ,
                      "διαθέτει δείγμα"@el .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#hasSpacetime
:hasSpacetime rdf:type owl:ObjectProperty ;
              rdfs:domain :Survey ;
              rdfs:range :Spacetime ;
              rdfs:label "hasSpacetime"@en ,
                         "ορίζεται σε χώρο και χρόνο"@el .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#hasSurvey
:hasSurvey rdf:type owl:ObjectProperty ;
           rdfs:domain :Dissertation ;
           rdfs:range :Survey ;
           rdfs:label "hasSurvey"@en ,
                      "περιλαμβάνει έρευνα"@el .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#hasWriter
:hasWriter rdf:type owl:ObjectProperty ;
           rdfs:domain :Dissertation ;
           rdfs:range :Writer ;
           rdfs:label "hasWriter"@en ,
                      "έχει συγγραφέα"@el .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#abstract
:abstract rdf:type owl:DatatypeProperty ;
          rdfs:domain :Dissertation ;
          rdfs:range xsd:string ;
          rdfs:label "abstract"@en ,
                     "Περίληψη"@el ;
          rdfs:seeAlso "http://purl.org/dc/terms/abstract"^^xsd:anyURI ,
                       "https://schema.org/abstract"^^xsd:anyURI .


###  http://www.semanticweb.org/team1/ontologies/semantic-web-project#altTitle
:altTitle rdf:type owl:DatatypeProperty ;
