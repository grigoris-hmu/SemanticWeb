:ThesisID_20 rdf:type owl:NamedIndividual ,
                   :DoctoralDissertation ;
          :hasSurvey :SurveyID_20 ;
          :hasWriter :WriterID_20 ;
          :abstract "Στόχος της παρούσας έρευνας ήταν να διερευνηθεί η σχέση των πολλαπλών τύπων νοημοσύνης και της αντίληψης του χώρου με τη στάση και την επίδοση των μαθητών στο μάθημα της Γεωγραφίας. Το δείγμα της έρευνας μας απαρτιζόταν από 600 μαθητές της Στ΄ τάξης Δημοτικού, ηλικίας 11-13 ετών που προέρχονταν από 22 διαφορετικά σχολεία της ελληνικής επικράτειας, κατανεμημένοι σε 33 διαφορετικές τάξεις." ;
          :alternativeHeadline "THE RELATION OF MULTIPLE INTELLIGENCES AND SPATIAL PERCERTION WITH PERFORMANCE AND ATTITUDE OF STUDENTS IN THE SUBJECT OF GEOGRAPHY" ;
          :dateOfSupport "2018-06-29"^^xsd:date ;
          :department "Σχολή Κοινωνικών Επιστημών Τμήμα Γεωγραφίας" ;
          :institution "Πανεπιστήμιο Αιγαίου" ;
          :language "ΕΛΛΗΝΙΚΑ" ;
          :libraryLink "http://hdl.handle.net/11610/20454" ;
          :nameOfSupervisor "Αικατερίνη Κλωνάρη" ;
          :numberOfPages "372" ;
          :title "Η Σχέση των πολλαπλών τύπων νοημοσύνης και της αντίληψης του χώρου με τη στάση και την επίδοση των μαθητών του Δημοτικού στο μάθημα της Γεωγραφίας" ;
          :typeOfDissertation "DoctoralDissertation" .
