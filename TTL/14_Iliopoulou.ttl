          :libraryLink "http://hdl.handle.net/11610/22124" ;
          :nameOfSupervisor "Στέφανος Χαρακτινιώτης" ;
          :numberOfPages "57" ;
          :program "ΠΡΟΓΡΑΜΜΑ ΜΕΤΑΠΤΥΧΙΑΚΩΝ ΣΠΟΥΔΩΝ ΣΤΗ ΔΙΟΙΗΚΗΣΗ ΕΠΙΧΕΙΡΗΣΕΩΝ (ΜΒΑ)" ;
          :title "ΟΙ ΣΥΝΑΛΛΑΓΕΣ ΜΕ ΤΑ ΣΥΝΔΕΔΕΜΕΝΑ ΜΕΡΗ ΥΠΟ ΤΟ ΠΡΙΣΜΑ ΤΟΥ ΝΕΟΥ ΝΟΜΟΥ 4548/2018" ;
